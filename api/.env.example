# Server
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commonground
DB_USER=commonground
DB_PASSWORD=changeme
DB_SSL=false

# CORS — origin of the frontend
CORS_ORIGIN=http://localhost:3001

# NWS API (no key required)
NWS_USER_AGENT=CommonGround/1.0 (contact@your-org.example)

# AirNow API key (register at https://www.airnowapi.org/)
AIRNOW_API_KEY=

# Rate limiting (requests per window per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Environment
NODE_ENV=development

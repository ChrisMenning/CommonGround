FROM node:20-alpine
WORKDIR /app

# Install production dependencies
COPY ingest/package.json ./
RUN npm install --omit=dev --no-audit --no-fund

# Copy ingest source
COPY ingest/ ./

# Non-root user for security
RUN addgroup -S cg && adduser -S cg -G cg

# Copy entrypoint script and make executable (must happen as root, before USER cg)
COPY docker/ingest-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER cg

CMD ["/entrypoint.sh"]
